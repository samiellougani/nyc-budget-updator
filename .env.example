# Anthropic API (required for summarization)
ANTHROPIC_API_KEY=
# Optional: override the summarization model (default: claude-sonnet-5)
ANTHROPIC_MODEL=

# Discord webhook for digest delivery (Server Settings -> Integrations ->
# Webhooks -> New Webhook -> Copy URL). Not needed for `make digest-dry`.
DISCORD_WEBHOOK_URL=

# NY Senate Open Legislation API key (free — see README)
NYSENATE_API_KEY=
