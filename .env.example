# Anthropic API (required for summarization)
ANTHROPIC_API_KEY=
# Optional: override the summarization model (default: claude-sonnet-5)
ANTHROPIC_MODEL=

# Twilio (required for SMS delivery; not needed for `make digest-dry`)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# NY Senate Open Legislation API key (free — see README)
NYSENATE_API_KEY=

# Local-only override: when set, ALL SMS goes only to this number and
# recipients.json is ignored. Leave unset in CI.
TEST_PHONE_NUMBER=
